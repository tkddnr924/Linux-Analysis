{
  "appId": "com.linuxanalysis.viewer",
  "productName": "Linux Analysis Viewer",
  "copyright": "Copyright © 2024",
  "directories": {
    "output": "dist",
    "buildResources": "assets"
  },

  "files": [
    "main.js",
    "preload.js",
    "renderer/**",
    "node_modules/**",
    "!node_modules/.cache/**",
    "!node_modules/.bin/**"
  ],

  "win": {
    "target": [
      { "target": "portable", "arch": ["x64"] }
    ]
  },
  "portable": {
    "artifactName": "${productName}.exe"
  },

  "mac": {
    "target": [
      { "target": "dmg",  "arch": ["x64", "arm64"] },
      { "target": "zip",  "arch": ["x64", "arm64"] }
    ],
    "category": "public.app-category.utilities"
  },

  "linux": {
    "target": [
      { "target": "AppImage", "arch": ["x64"] },
      { "target": "deb",      "arch": ["x64"] }
    ],
    "category": "Utility"
  }
}
